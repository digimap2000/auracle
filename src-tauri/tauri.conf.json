{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Auracle",
  "version": "0.1.0",
  "identifier": "com.auracle.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Auracle",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEIwQjdBMkU2QjFDN0IyQjQKUldTMHNzZXg1cUszc0RvM05WR1ljUXdER09iMGVENmE4d2ZyUXlYc1NEaFJMVlZXWndkdUd1ck8K",
      "endpoints": [
        "https://github.com/digimap2000/auracle/releases/latest/download/latest.json"
      ]
    }
  }
}
